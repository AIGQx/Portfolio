---
import { Image } from "astro:assets";
import logo from "../assets/portfolio.webp";
import { loadLang } from "../scripts/langScript";
import '../styles/global.css';
import '../styles/view.css';
//language detector script
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/Alejandro Galarza.webp" />
		<meta name="generator" content={Astro.generator} />
		<title>Alejandro Galarza</title>
	</head>
	<body class="bg-ctp-base font-sans">
		<nav class="absolute w-full flex items-center">
			<div
				class="flex w-full justify-between items-center space-x-4 px-4 py-4"
			>
				<a href="/"
					><Image
						loading="eager"
						src={logo}
						alt="logo"
						class="h-12 w-12 rounded-full"
					/>
				</a>
				<ul
					class="flex flex-row space-x-4 text-ctp-text font-bold p-2 rounded-lg"
				>
					<li
						class="hover:text-ctp-mauve transition duration-200 ease-in-out"
					>
						<a
							href="/"
							class="flex flex-row gap-2 items-center font-thin lang"
							><p class="hidden">Español</p><svg
								class="h-8 w-8"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
							>
								<path d="M4 5h7"></path>
								<path d="M7 4c0 4.846 0 7 .5 8"></path>
								<path
									d="M10 8.5c0 2.286 -2 4.5 -3.5 4.5s-2.5 -1.135 -2.5 -2c0 -2 1 -3 3 -3s5 .57 5 2.857c0 1.524 -.667 2.571 -2 3.143"
								></path>
								<path d="M12 20l4 -9l4 9"></path>
								<path d="M19.1 18h-6.2"></path>
							</svg></a
						>
					</li>
				</ul>
			</div>
		</nav>
		<main class="w-full flex flex-row items-center justify-center">
			<slot />
		</main>
		<div id="scroll-markers" class="markers row absolute">
				<div class="marker active" id="main-marker" data-index="0" aria-label="Main section" title="Main"></div>
				<div class="marker" id="projects-marker" data-index="1" aria-label="Projects section" title="Projects"></div>
				<div class="marker" id="experience-marker" data-index="2" aria-label="Experience section" title="Experience"></div>
				<div class="marker" id="contact-marker" data-index="3" aria-label="Contact section" title="Contact"></div>
		</div>
		<script>
			//language selector script
			var lang = document.querySelector(".lang");

			if (lang) {
				lang.addEventListener("mouseover", () => {
					if (lang?.firstChild) {
						lang.children[0].classList.remove("hidden");
					}
				});
				lang.addEventListener("mouseout", () => {
					if (lang?.firstChild) {
						lang.children[0].classList.add("hidden");
					}
				});
			}
			//carousel script
			// @ts-nocheck
			var track = document.getElementById("carousel-track") as HTMLElement | null;
			var markersContainer = document.getElementById("scroll-markers") as HTMLElement | null;

			if (track && markersContainer) {
				var markers = Array.from(markersContainer.querySelectorAll<HTMLElement>(".marker"));
				var totalSlides = track.children.length;
				var currentIndex = 0;

				var setActiveMarker = (index: number) => {
					markers.forEach((marker: HTMLElement, markerIndex: number) => {
						if (markerIndex === index || (index === totalSlides - 1 && marker.id === "footer-marker")) {
							marker.classList.add("active");
						} else if (marker.id !== "footer-marker" || index !== totalSlides - 1) {
							marker.classList.remove("active");
						}
					});
				};

				var goToSlide = (index: number) => {
					if (index < 0 || index >= totalSlides) return;
					currentIndex = index;
					track?.style.setProperty("transform", `translateX(-${index * 100}%)`);
					setActiveMarker(index);
				};

				markers.forEach((marker) => {
					marker.setAttribute("tabindex", "0");
					marker.setAttribute("role", "button");

					var navigate = () => {
						var markerIndex = Number(marker.dataset.index);
						goToSlide(markerIndex);
					};

					marker.addEventListener("click", navigate);
					marker.addEventListener("keydown", (event: KeyboardEvent) => {
						if (event.key === "Enter" || event.key === " ") {
							event.preventDefault();
							navigate();
						}
					});
				});

				document.addEventListener("keydown", (event: KeyboardEvent) => {
					if (event.key === "ArrowRight" || event.key === "ArrowDown") {
						goToSlide(Math.min(currentIndex + 1, totalSlides - 1));
					}
					if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
						goToSlide(Math.max(currentIndex - 1, 0));
					}
				});

				goToSlide(0);
			}
		</script>
		<style>
			html,
			body {
				margin: 0;
				width: 100%;
				height: 100%;
			}
		</style>
	</body>
</html>

				href="credits"
				class="flex w-1/2 items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-ctp-lavender to-ctp-blue px-3 py-3"
			>
				<p>Creditos</p>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"

<header
	class="section-info mx-auto flex min-h-svh w-full max-w-7xl flex-col gap-10 px-6 py-16 text-ctp-text leading-relaxed tracking-tight lg:flex-row lg:items-center lg:justify-between lg:px-12"
>
	<div class="my-auto flex w-full max-w-3xl flex-col items-start justify-center lg:w-3/5 lg:pl-6">
		<div
			class="box-decoration-clone bg-gradient-to-r text-transparent from-ctp-pink to-ctp-mauve bg-clip-text select-none"
		>
			<h1 class="font-extrabold text-6xl md:text-9xl">Alejandro</h1>
			<div class="flex flex-row items-center gap-4">
				<h1 class="font-extrabold text-6xl md:text-9xl">Galarza</h1>
				<svg
					class="align-middle text-ctp-mauve text-4xl md:text-6xl"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
				>
					<path d="M7 8l-4 4l4 4"></path>
					<path d="M17 8l4 4l-4 4"></path>
					<path d="M14 4l-4 16"></path>
				</svg>
			</div>
		</div>
		<p class="my-4 font-light text-base text-ctp-subtext0 md:text-xl">
			Desarrollador de software
		</p>
		<a
			class="inline-flex flex-row items-center gap-2 rounded-lg bg-gradient-to-r from-ctp-red to-ctp-peach px-4 py-2 font-bold text-ctp-mantle"
			href="/cv.pdf"
		>
			Descargar CV

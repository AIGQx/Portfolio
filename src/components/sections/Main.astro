		<div class="flex w-full flex-row gap-3">
			<a
				href="#contact"
				class="flex w-1/2 items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-ctp-mauve to-ctp-pink px-3 py-3"
				>Contacto

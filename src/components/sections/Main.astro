				href="#projects"
				class="flex w-1/2 items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-ctp-pink to-ctp-flamingo px-3 py-3"
			>
				<p class="text-1sm">Proyectos</p>
				<svg
					viewBox="0 0 24 24"
					fill="none"
					width="24"
					height="24"
					stroke-width="2"
					stroke-linejoin="round"
